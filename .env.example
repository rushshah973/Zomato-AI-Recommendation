# LLM provider — Google Gemini (Google AI Studio)
LLM_PROVIDER=gemini
LLM_API_KEY=
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.3

# Hugging Face dataset
HF_DATASET_ID=ManikaSaini/zomato-restaurant-recommendation

# Pipeline limits
MAX_CANDIDATES=30
TOP_K=5

# Budget band thresholds (INR, cost for two)
BUDGET_LOW_MAX=500
BUDGET_MEDIUM_MAX=1500
# Optional JSON override: {"low_max": 500, "medium_max": 1500}
BUDGET_THRESHOLDS=

# Optional: path for preprocessed dataset cache
DATA_CACHE_PATH=.cache/restaurants.parquet
